{
  "name": "handymedia",
  "version": "1.0.1",
  "description": "Bypass YouTube Shorts by converting portrait videos to landscape with padded black bars.",
  "author": "Mosh Feu",
  "main": "dist-electron/main.js",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "vite",
    "publish": "npx electron-builder --publish always",
    "local-pack": "yarn build && electron-builder --dir && open dist_build/mac-arm64/HandyMedia.app"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/ffmpeg-static": "^5.1.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^25.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "electron-icon-builder": "^2.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
